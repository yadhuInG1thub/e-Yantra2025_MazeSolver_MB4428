module botrun
(
    output reg ena,
    output reg in1,
    output reg in2,
    output reg enb,
    output reg in3,
    output reg in4,

    input en1a,
    input en2a,
    input en1b,
    input en2b,

    output reg [15:0] cen1a_p,
    output reg [15:0] cen1b_p,
    output reg [15:0] cen2a_p,
    output reg [15:0] cen2b_p,

    output reg pwmsignal,
    output reg clk3,
    input clk50
);

reg [11:0] roter;
reg [3:0] pwm_counter;
reg [3:0] duty_cycle;
reg [1:0] clk6;

initial begin
    cen1a_p = 16'd0;
    cen2a_p = 16'd0;
    cen1b_p = 16'd0;
    cen2b_p = 16'd0;

    ena = 1'b0;
    in1 = 1'b0;
    in2 = 1'b1;
    enb = 1'b0;
    in3 = 1'b0; 
    in4 = 1'b1;

    roter = 12'd0;
    pwm_counter = 4'd0;
    duty_cycle = 4'd9;

    pwmsignal = 1'b1;
    clk3 = 1'b0;
    clk6 = 2'd0;
end

always @(posedge clk50) begin
    if (pwm_counter < duty_cycle)
        pwmsignal = 1'b1;
    else
        pwmsignal = 1'b0;

    pwm_counter = pwm_counter + 4'd1;
    enb = pwmsignal;
    ena = 1'b1;
end

endmodule
